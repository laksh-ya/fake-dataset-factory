plt.ylabel('Count')
plt.title('Distribution of Pneumonia Scores (DCGAN Generated Images)')
plt.legend()
plt.tight_layout()
plt.savefig(OUTPUT_DIR / "pneumonia_scores.png", dpi=150)
plt.show()





# create labels dataframe
labels_df = pd.DataFrame({
